model InstitutionApplication {
  id String @id @default(uuid())

  applicantUserId String
  applicantUser User @relation("InstitutionApplicationApplicant", fields: [applicantUserId], references: [id])

  institutionName String
  description String?
  shortName String?
  institutionType InstitutionType?
  institutionLogo String?

  subscriptionPlan InstitutionSubscriptionPlan?
  subscriptionAmount Decimal? @db.Decimal(12, 2)
  subscriptionCurrency String @default("BDT")
  subscriptionMonths Int?
  subscriptionPaymentStatus InstitutionSubscriptionPaymentStatus @default(PENDING)
  subscriptionTranId String? @unique
  subscriptionGatewayStatus String?
  subscriptionGatewaySessionKey String? @unique
  subscriptionGatewayValId String?
  subscriptionGatewayBankTranId String?
  subscriptionGatewayCardType String?
  subscriptionGatewayRawPayload Json?
  subscriptionPaidAt DateTime?

  status InstitutionApplicationStatus @default(PENDING)
  rejectionReason String?

  reviewedByUserId String?
  reviewedByUser User? @relation("InstitutionApplicationReviewedBy", fields: [reviewedByUserId], references: [id])
  reviewedAt DateTime?

  institutionId String?
  institution Institution? @relation(fields: [institutionId], references: [id])
  subscriptions InstitutionSubscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([applicantUserId])
  @@index([status])
  @@map("institution_applications")
}
