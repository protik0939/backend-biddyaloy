model Department {
    id          String  @id @default(uuid())
    fullName    String
    shortName   String?
    description String?

    facultyId String?
    faculty   Faculty? @relation(fields: [facultyId], references: [id])

    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt

    programs  Program[]
    batches Batch[]
    courses Course[]
    sections  Section[]
    teacherProfiles TeacherProfile[]
    studentProfiles StudentProfile[]
    courseRegistrations CourseRegistration[]
    sectionTeacherAssignments SectionCourseTeacherAssignment[]
    teacherJobApplications TeacherJobApplication[]
    teacherClassworks TeacherClasswork[]
    studentClassworkSubmissions StudentClassworkSubmission[]
    teacherMarks TeacherMark[]

    @@map("departments")
}
