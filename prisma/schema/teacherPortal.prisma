model TeacherJobApplication {
    id String @id @default(uuid())
    coverLetter String?
    status TeacherJobApplicationStatus @default(PENDING)
    institutionResponse String?
    reviewedAt DateTime?
    appliedAt DateTime @default(now())

    postingId String
    posting TeacherJobPost @relation(fields: [postingId], references: [id])

    teacherUserId String
    teacherUser User @relation("TeacherJobApplicationApplicant", fields: [teacherUserId], references: [id])

    reviewerUserId String?
    reviewerUser User? @relation("TeacherJobApplicationReviewer", fields: [reviewerUserId], references: [id])

    teacherProfileId String?
    teacherProfile TeacherProfile? @relation(fields: [teacherProfileId], references: [id])

    institutionId String
    institution Institution @relation(fields: [institutionId], references: [id])

    departmentId String?
    department Department? @relation(fields: [departmentId], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([postingId, teacherUserId])
    @@index([teacherUserId])
    @@index([institutionId, status])
    @@map("teacher_job_applications")
}

model TeacherClasswork {
    id String @id @default(uuid())
    title String
    content String?
    type TeacherClassworkType
    dueAt DateTime?

    sectionId String
    section Section @relation(fields: [sectionId], references: [id])

    teacherProfileId String
    teacherProfile TeacherProfile @relation(fields: [teacherProfileId], references: [id])

    institutionId String
    institution Institution @relation(fields: [institutionId], references: [id])

    departmentId String?
    department Department? @relation(fields: [departmentId], references: [id])

    submissions StudentClassworkSubmission[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([teacherProfileId, createdAt])
    @@index([sectionId, type])
    @@map("teacher_classworks")
}

model StudentClassworkSubmission {
    id String @id @default(uuid())

    classworkId String
    classwork TeacherClasswork @relation(fields: [classworkId], references: [id])

    studentProfileId String
    studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id])

    responseText String?
    attachmentUrl String?
    attachmentName String?
    submittedAt DateTime @default(now())

    institutionId String
    institution Institution @relation(fields: [institutionId], references: [id])

    departmentId String?
    department Department? @relation(fields: [departmentId], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([classworkId, studentProfileId])
    @@index([studentProfileId, submittedAt])
    @@index([institutionId])
    @@map("student_classwork_submissions")
}

model SectionCourseTeacherAssignment {
    id String @id @default(uuid())

    sectionId String
    section Section @relation(fields: [sectionId], references: [id])

    courseId String
    course Course @relation(fields: [courseId], references: [id])

    teacherProfileId String
    teacherProfile TeacherProfile @relation(fields: [teacherProfileId], references: [id])

    institutionId String
    institution Institution @relation(fields: [institutionId], references: [id])

    departmentId String?
    department Department? @relation(fields: [departmentId], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([sectionId, courseId])
    @@index([teacherProfileId, createdAt])
    @@index([institutionId])
    @@map("section_course_teacher_assignments")
}

model TeacherApplicationProfile {
    id String @id @default(uuid())

    teacherUserId String @unique
    teacherUser User @relation(fields: [teacherUserId], references: [id])

    headline String
    about String
    resumeUrl String
    portfolioUrl String?

    skills String[]
    certifications String[]
    academicRecords Json
    experiences Json

    isComplete Boolean @default(false)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("teacher_application_profiles")
}