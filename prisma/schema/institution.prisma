model Institution {
    id              String           @id @default(uuid())
    name            String
    description     String?
    shortName       String?
    type            InstitutionType?
    institutionLogo String?
    createdAt       DateTime         @default(now())
    updatedAt       DateTime         @updatedAt
    faculties       Faculty[]
    programs        Program[]
    batches         Batch[]
    classrooms      ClassRoom[]
    sections        Section[]
    courses         Course[]
    adminProfile    AdminProfile[]
    teacherProfiles  TeacherProfile[]
    studentProfiles  StudentProfile[]
    courseRegistrations CourseRegistration[]
    sectionTeacherAssignments SectionCourseTeacherAssignment[]
    institutionApplications InstitutionApplication[]
    teacherJobApplications TeacherJobApplication[]
    teacherClassworks TeacherClasswork[]
    studentClassworkSubmissions StudentClassworkSubmission[]
    teacherMarks TeacherMark[]
    feeConfigurations DepartmentSemesterFeeConfiguration[]
    feePayments StudentFeePayment[]
    paymentGatewayCredential InstitutionPaymentGatewayCredential?
    subscriptions InstitutionSubscription[]
    schedules Schedule[]
    routines Routine[]
    notices Notice[]
    leaveRequests InstitutionLeaveRequest[]
    sourceTransferRequests InstitutionTransferRequest[] @relation("TransferRequestSourceInstitution")
    targetTransferRequests InstitutionTransferRequest[] @relation("TransferRequestTargetInstitution")

    @@map("institutions")
}
