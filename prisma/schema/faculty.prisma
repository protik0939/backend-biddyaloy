
model Faculty {
    id          String  @id @default(uuid())
    fullName    String
    shortName   String?
    description String?

    institutionId String?
    institution   Institution? @relation(fields: [institutionId], references: [id])

    createdAt   DateTime     @default(now())
    updatedAt   DateTime     @updatedAt
    departments Department[]


    @@map("faculties")
}
