# Backend runtime contract
DATABASE_URL=

# Public URL for backend app
BACKEND_PUBLIC_URL=https://your-backend-domain.vercel.app

# Allowed frontend production origin (exact match)
FRONTEND_PUBLIC_URL=https://your-frontend-domain.vercel.app

# Optional regex for Vercel preview frontend origins
# Example: ^https://frontend-biddyaloy-git-.*-yourteam\.vercel\.app$
FRONTEND_PREVIEW_URL_PATTERN=

# Optional comma-separated additional allowed origins
FRONTEND_ALLOWED_ORIGINS=

# Shared auth secret value (must match frontend AUTH_SECRET)
AUTH_SECRET=

# Runtime environment
NODE_ENV=production

# Existing seed variables
SUPER_ADMIN_NAME=
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASS=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
MAIL_FROM="Biddyaloy <your-email@gmail.com>"